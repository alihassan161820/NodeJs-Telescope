{
  "name": "@node-telescope/core",
  "version": "1.0.0",
  "description": "Core engine for Node-Telescope — Laravel Telescope for Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "telescope",
    "laravel-telescope",
    "debugging",
    "monitoring",
    "observability",
    "devtools",
    "developer-tools",
    "debug-dashboard",
    "request-logger",
    "api-debugger",
    "error-tracking",
    "query-monitor",
    "http-logger",
    "application-monitoring",
    "logging-dashboard",
    "express",
    "nestjs",
    "fastify",
    "nodejs",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alihassan161820/NodeJs-Telescope.git",
    "directory": "packages/core"
  },
  "author": "Ali Hassan",
  "homepage": "https://github.com/alihassan161820/NodeJs-Telescope#readme",
  "bugs": {
    "url": "https://github.com/alihassan161820/NodeJs-Telescope/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
