{
  "name": "@node-telescope/fastify",
  "version": "0.1.0",
  "description": "Fastify plugin adapter for Node-Telescope",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@node-telescope/core": "^0.1.0",
    "fastify": "^5.0.0",
    "@node-telescope/storage-sqlite": "^0.1.0",
    "@node-telescope/dashboard": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@node-telescope/storage-sqlite": {
      "optional": true
    },
    "@node-telescope/dashboard": {
      "optional": true
    }
  },
  "devDependencies": {
    "@node-telescope/core": "workspace:*",
    "@node-telescope/storage-sqlite": "workspace:*",
    "@node-telescope/dashboard": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "fastify": "^5.0.0",
    "@fastify/static": "^8.0.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "telescope",
    "debugging",
    "monitoring",
    "fastify",
    "plugin",
    "node"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/node-telescope/node-telescope.git",
    "directory": "packages/fastify"
  },
  "author": "Ali Hassan",
  "homepage": "https://github.com/node-telescope/node-telescope#readme",
  "bugs": {
    "url": "https://github.com/node-telescope/node-telescope/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
