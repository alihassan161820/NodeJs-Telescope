{
  "name": "@node-telescope/storage-postgres",
  "version": "1.0.0",
  "description": "PostgreSQL storage backend for Node-Telescope using pg",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "peerDependencies": {
    "@node-telescope/core": "^1.0.0"
  },
  "devDependencies": {
    "@node-telescope/core": "workspace:*",
    "@types/pg": "^8.11.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "telescope",
    "laravel-telescope",
    "postgres",
    "postgresql",
    "storage",
    "monitoring",
    "observability",
    "debugging",
    "devtools",
    "nodejs",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alihassan161820/NodeJs-Telescope.git",
    "directory": "packages/storage-postgres"
  },
  "author": "Ali Hassan",
  "homepage": "https://github.com/alihassan161820/NodeJs-Telescope#readme",
  "bugs": {
    "url": "https://github.com/alihassan161820/NodeJs-Telescope/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
